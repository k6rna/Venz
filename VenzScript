            optBtn.TextSize = 12
            optBtn.Font = Enum.Font.Gotham
            optBtn.BorderSizePixel = 0
            optBtn.ZIndex = 10
            optBtn.Parent = content
            Instance.new("UICorner", optBtn).CornerRadius = UDim.new(0,6)
            optBtn.MouseButton1Click:Connect(function()
                dropBtn.Text = opt .. " ▾"
                callback(opt)
                closeMenu()
            end)
            table.insert(optFrames, optBtn)
        end
    end)
