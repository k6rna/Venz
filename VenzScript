MakeButton("✅ Apply Skin", 938, function()
    if not selectedTexture then scanStatusLbl.Text = "⚠️ Select a slot first!" return end
    local newId = inputBox.Text
    if newId == "" then scanStatusLbl.Text = "⚠️ Enter a texture ID!" return end
    if not newId:match("^rbxassetid://") and not newId:match("^http") then
        newId = "rbxassetid://" .. newId
    end
    local obj = selectedTexture.obj
    local success = false
    if obj:IsA("SpecialMesh") then obj.TextureId = newId; success = true
    elseif obj:IsA("Decal") then obj.Texture = newId; success = true
    elseif obj:IsA("Texture") then obj.Texture = newId; success = true
    elseif obj:IsA("MeshPart") then obj.TextureID = newId; success = true
    elseif obj:IsA("SurfaceAppearance") then
        local mt = selectedTexture.mapType
        if mt == "ColorMap"     then obj.ColorMap     = newId; success = true
        elseif mt == "NormalMap"    then obj.NormalMap    = newId; success = true
        elseif mt == "RoughnessMap" then obj.RoughnessMap = newId; success = true
        elseif mt == "MetalnessMap" then obj.MetalnessMap = newId; success = true
        end
