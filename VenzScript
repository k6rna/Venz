-- Apply skin button
MakeButton("✅ Apply Skin (client only)", 840, function()
    if not selectedTexture then
        scanStatusLbl.Text = "⚠️ Select a texture slot first!"
        return
    end
    local newId = inputBox.Text
    if newId == "" then
        scanStatusLbl.Text = "⚠️ Enter a texture ID first!"
        return
    end

    -- Prefix rbxassetid:// if needed
    if not newId:match("^rbxassetid://") and not newId:match("^http") then
        newId = "rbxassetid://" .. newId
    end

    local obj = selectedTexture.obj
    local success = false

    if obj:IsA("SpecialMesh") then
        obj.TextureId = newId; success = true
    elseif obj:IsA("Decal") then
        obj.Texture = newId; success = true
    elseif obj:IsA("Texture") then
        obj.Texture = newId; success = true
    elseif obj:IsA("SurfaceAppearance") then
        obj.ColorMap = newId; success = true
    elseif obj:IsA("MeshPart") then
        obj.TextureID = newId; success = true
    end

    if success then
        scanStatusLbl.Text = "✅ Skin applied! (client-side only)"
        selectedTexture.id = newId
    else
        scanStatusLbl.Text = "❌ Could not apply skin to this slot"
    end
end)

