    if obj:IsA("SpecialMesh") then obj.TextureId = orig
    elseif obj:IsA("Decal") then obj.Texture = orig
    elseif obj:IsA("Texture") then obj.Texture = orig
    elseif obj:IsA("SurfaceAppearance") then obj.ColorMap = orig
    elseif obj:IsA("MeshPart") then obj.TextureID = orig end
    scanStatusLbl.Text = "🔄 Skin reset to original"
end)

