-- ================================================
--   FIND GUN — searches character, backpack AND workspace
-- ================================================
local function FindEquippedGun()
    local char = LocalPlayer.Character

    -- 1. Check character first (equipped)
    if char then
        for _, obj in ipairs(char:GetChildren()) do
            if obj:IsA("Tool") then return obj, "character" end
        end
    end

    -- 2. Check backpack
    for _, obj in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if obj:IsA("Tool") then return obj, "backpack" end
    end

    -- 3. Check workspace for a model that belongs to local player
    --    (some games parent guns to workspace when dropped)
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then
            for _, obj in ipairs(workspace:GetChildren()) do
                if obj:IsA("Tool") or obj:IsA("Model") then
                    -- Check if it's near the player
                    local part = obj:FindFirstChildWhichIsA("BasePart", true)
                    if part and (part.Position - root.Position).Magnitude < 10 then
                        return obj, "workspace"
                    end
                end
            end
        end
    end

    return nil, nil
end

local function ScanGunTextures()
    ClearSkinList()

    local tool, location = FindEquippedGun()

    if not tool then
        scanStatusLbl.Text = "❌ No gun found! Try equipping it first."
        return
    end

    scanStatusLbl.Text = "🔍 Scanning: " .. tool.Name .. " (from " .. location .. ")"

    local found = {}
    local seen = {}

    for _, desc in ipairs(tool:GetDescendants()) do
        local texId = nil
        local obj = desc

        if desc:IsA("SpecialMesh") and desc.TextureId ~= "" then
            texId = desc.TextureId
        elseif desc:IsA("Decal") and desc.Texture ~= "" then
            texId = desc.Texture
        elseif desc:IsA("Texture") and desc.Texture ~= "" then
            texId = desc.Texture
        elseif desc:IsA("MeshPart") and desc.TextureID ~= "" then
            texId = desc.TextureID
            obj = desc
        elseif desc:IsA("SurfaceAppearance") then
            local maps = {
                {desc.ColorMap,      "ColorMap"},
                {desc.NormalMap,     "NormalMap"},
                {desc.RoughnessMap,  "RoughnessMap"},
                {desc.MetalnessMap,  "MetalnessMap"},
            }
            for _, map in ipairs(maps) do
                if map[1] ~= "" and not seen[map[1]] then
                    seen[map[1]] = true
                    table.insert(found, {
                        obj  = desc,
                        id   = map[1],
                        name = (desc.Parent and desc.Parent.Name or "?") .. " > " .. map[2],
                        mapType = map[2],
                    })
                end
            end
        end

        if texId and not seen[texId] then
            seen[texId] = true
            table.insert(found, {
                obj  = obj,
                id   = texId,
                name = (desc.Parent and desc.Parent.Name or "?") .. "." .. desc.Name,
                mapType = nil,
            })
        end
    end

    if #found == 0 then
        scanStatusLbl.Text = "⚠️ No textures found on " .. tool.Name .. ". Try the other gun slot."
        return
    end

    scanStatusLbl.Text = "✅ " .. #found .. " texture(s) on " .. tool.Name
    scannedTextures = found

    for i, tex in ipairs(found) do
        local row = Instance.new("TextButton")
        row.Size = UDim2.new(1,0,0,38)
        row.BackgroundColor3 = Color3.fromRGB(35,35,35)
        row.BorderSizePixel = 0
        row.AutoButtonColor = false
        row.LayoutOrder = i
        row.Parent = skinListFrame
        Instance.new("UICorner", row).CornerRadius = UDim.new(0,5)

        local nameLbl = Instance.new("TextLabel")
        nameLbl.Size = UDim2.new(1,-8,0,18)
        nameLbl.Position = UDim2.new(0,6,0,2)
        nameLbl.BackgroundTransparency = 1
        nameLbl.Text = "📌 " .. tex.name
        nameLbl.TextColor3 = Color3.fromRGB(200,200,200)
        nameLbl.TextSize = 11
        nameLbl.Font = Enum.Font.GothamBold
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        nameLbl.TextTruncate = Enum.TextTruncate.AtEnd
        nameLbl.Parent = row

        local idLbl = Instance.new("TextLabel")
        idLbl.Size = UDim2.new(1,-8,0,14)
        idLbl.Position = UDim2.new(0,6,0,22)
        idLbl.BackgroundTransparency = 1
        idLbl.Text = tex.id
        idLbl.TextColor3 = Color3.fromRGB(0,180,90)
        idLbl.TextSize = 10
        idLbl.Font = Enum.Font.Gotham
        idLbl.TextXAlignment = Enum.TextXAlignment.Left
        idLbl.TextTruncate = Enum.TextTruncate.AtEnd
        idLbl.Parent = row

        row.MouseButton1Click:Connect(function()
            for _, r in ipairs(skinListFrame:GetChildren()) do
                if r:IsA("TextButton") then r.BackgroundColor3 = Color3.fromRGB(35,35,35) end
            end
            row.BackgroundColor3 = Color3.fromRGB(0,100,50)
            selectedTexture = tex
            inputBox.Text = tex.id
        end)
        row.MouseEnter:Connect(function()
            if selectedTexture ~= tex then row.BackgroundColor3 = Color3.fromRGB(50,50,50) end
        end)
        row.MouseLeave:Connect(function()
            if selectedTexture ~= tex then row.BackgroundColor3 = Color3.fromRGB(35,35,35) end
        end)
    end

    skinListFrame.CanvasSize = UDim2.new(0,0,0,#found*42+8)
end

