local function ScanGunTextures()
    ClearSkinList()
    local char = LocalPlayer.Character
    if not char then
        scanStatusLbl.Text = "❌ No character found!"
        return
    end

    -- Find equipped tool
    local tool = nil
    for _, obj in ipairs(char:GetChildren()) do
        if obj:IsA("Tool") then tool = obj break end
    end
    if not tool then
        -- also check backpack
        for _, obj in ipairs(LocalPlayer.Backpack:GetChildren()) do
            if obj:IsA("Tool") then tool = obj break end
        end
    end
    if not tool then
        scanStatusLbl.Text = "❌ No gun equipped! Equip a gun first."
        return
    end

    scanStatusLbl.Text = "🔍 Scanning: " .. tool.Name

    -- Scan all descendants for textures
    local found = {}
    for _, desc in ipairs(tool:GetDescendants()) do
        local texId = nil
        local obj = desc

        if desc:IsA("SpecialMesh") and desc.TextureId ~= "" then
            texId = desc.TextureId
        elseif desc:IsA("Decal") and desc.Texture ~= "" then
            texId = desc.Texture
        elseif desc:IsA("Texture") and desc.Texture ~= "" then
            texId = desc.Texture
        elseif desc:IsA("SurfaceAppearance") then
            -- Check all maps
            local maps = {desc.ColorMap, desc.NormalMap, desc.RoughnessMap, desc.MetalnessMap}
            for _, map in ipairs(maps) do
                if map ~= "" then
                    table.insert(found, {obj = desc, id = map, name = desc.Parent.Name .. " (" .. desc.ClassName .. ")"})
                end
            end
        elseif desc:IsA("MeshPart") and desc.TextureID ~= "" then
            texId = desc.TextureID
            obj = desc
        end

        if texId then
            table.insert(found, {obj = obj, id = texId, name = desc.Parent.Name .. "." .. desc.Name})
        end
    end

    if #found == 0 then
        scanStatusLbl.Text = "⚠️ No textures found on " .. tool.Name
        return
    end

    scanStatusLbl.Text = "✅ Found " .. #found .. " texture(s) on " .. tool.Name
    scannedTextures = found

    -- Build list
    for i, tex in ipairs(found) do
        local row = Instance.new("TextButton")
        row.Size = UDim2.new(1,0,0,36)
        row.BackgroundColor3 = Color3.fromRGB(35,35,35)
        row.BorderSizePixel = 0
        row.AutoButtonColor = false
        row.LayoutOrder = i
        row.Parent = skinListFrame
        Instance.new("UICorner", row).CornerRadius = UDim.new(0,5)

        local nameLbl = Instance.new("TextLabel")
        nameLbl.Size = UDim2.new(1,-8,0,18)
        nameLbl.Position = UDim2.new(0,6,0,2)
        nameLbl.BackgroundTransparency = 1
        nameLbl.Text = "📌 " .. tex.name
        nameLbl.TextColor3 = Color3.fromRGB(200,200,200)
        nameLbl.TextSize = 11
        nameLbl.Font = Enum.Font.GothamBold
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        nameLbl.TextTruncate = Enum.TextTruncate.AtEnd
        nameLbl.Parent = row

        local idLbl = Instance.new("TextLabel")
        idLbl.Size = UDim2.new(1,-8,0,14)
        idLbl.Position = UDim2.new(0,6,0,20)
        idLbl.BackgroundTransparency = 1
        idLbl.Text = tex.id
        idLbl.TextColor3 = Color3.fromRGB(0,180,90)
        idLbl.TextSize = 10
        idLbl.Font = Enum.Font.Gotham
        idLbl.TextXAlignment = Enum.TextXAlignment.Left
        idLbl.TextTruncate = Enum.TextTruncate.AtEnd
        idLbl.Parent = row

        row.MouseButton1Click:Connect(function()
            -- deselect all
            for _, r in ipairs(skinListFrame:GetChildren()) do
                if r:IsA("TextButton") then
                    r.BackgroundColor3 = Color3.fromRGB(35,35,35)
                end
            end
            row.BackgroundColor3 = Color3.fromRGB(0,100,50)
            selectedTexture = tex
            inputBox.Text = tex.id
        end)

        row.MouseEnter:Connect(function()
            if selectedTexture ~= tex then
                row.BackgroundColor3 = Color3.fromRGB(50,50,50)
            end
        end)
        row.MouseLeave:Connect(function()
            if selectedTexture ~= tex then
                row.BackgroundColor3 = Color3.fromRGB(35,35,35)
            end
        end)
    end

    skinListFrame.CanvasSize = UDim2.new(0,0,0, #found * 40 + 8)
end

