-- Selected texture tracker
local selectedTexture = nil
local scannedTextures = {}

local function ClearSkinList()
    for _, c in ipairs(skinListFrame:GetChildren()) do
        if c:IsA("TextButton") or c:IsA("Frame") then c:Destroy() end
    end
    scannedTextures = {}
    selectedTexture = nil
