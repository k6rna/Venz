local function MakeDropdown(labelText, yPos, options, callback)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1,-20,0,30)
    container.Position = UDim2.new(0,10,0,yPos)
    container.BackgroundTransparency = 1
    container.Parent = content

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.5,0,1,0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = Color3.fromRGB(220,220,220)
    lbl.TextSize = 13
    lbl.Font = Enum.Font.Gotham
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = container

    local selected = options[1]
    local dropBtn = Instance.new("TextButton")
    dropBtn.Size = UDim2.new(0.48,0,1,0)
    dropBtn.Position = UDim2.new(0.52,0,0,0)
    dropBtn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    dropBtn.Text = selected .. " ▾"
    dropBtn.TextColor3 = Color3.fromRGB(0,180,90)
    dropBtn.TextSize = 12
    dropBtn.Font = Enum.Font.GothamBold
    dropBtn.BorderSizePixel = 0
    dropBtn.Parent = container
    Instance.new("UICorner", dropBtn).CornerRadius = UDim.new(0,6)

    local open = false
    local optFrames = {}

    local function closeMenu()
        open = false
        for _, f in ipairs(optFrames) do f:Destroy() end
        optFrames = {}
    end

    dropBtn.MouseButton1Click:Connect(function()
        if open then closeMenu() return end
        open = true
        for i, opt in ipairs(options) do
            local optBtn = Instance.new("TextButton")
            optBtn.Size = UDim2.new(0.48,0,0,26)
            optBtn.Position = UDim2.new(0.52,0,0,yPos + 30 + (i-1)*28)
            optBtn.BackgroundColor3 = Color3.fromRGB(40,40,40)
            optBtn.Text = opt
            optBtn.TextColor3 = Color3.fromRGB(220,220,220)
            optBtn.TextSize = 12
            optBtn.Font = Enum.Font.Gotham
            optBtn.BorderSizePixel = 0
            optBtn.ZIndex = 10
            optBtn.Parent = content
            Instance.new("UICorner", optBtn).CornerRadius = UDim.new(0,6)
            optBtn.MouseButton1Click:Connect(function()
                selected = opt
                dropBtn.Text = opt .. " ▾"
                callback(opt)
                closeMenu()
            end)
            table.insert(optFrames, optBtn)
        end
    end)
end

